        { "name": "onToggleSave", "type": "VoidCallback" }
      ],
      "description": "Barra de acción con un único botón: bookmark (🔖). Si isSaved → icono filled AppColors.primary; si no → icono outline AppColors.textSecondary. Sin likes (♥), sin comentarios (💬).",
      "actions_NOT_to_include": ["likeButton", "likeCount", "commentButton", "commentCount"],
      "tokens": ["AppSpacing.md", "AppColors.primary", "AppColors.textSecondary"],
