    {
      "file": "lib/features/articles/presentation/widgets/related_articles_section.dart",
      "class": "RelatedArticlesSection",
      "type": "StatelessWidget",
      "props": [
        { "name": "articles", "type": "List<ArticleEntity>" },
        { "name": "onArticleTap", "type": "void Function(String articleId)" }
      ],
      "description": "Sección 'Más como esto' con título (AppTypography.titleSm) y ListView horizontal de ArticleCard. Si articles.isEmpty → SizedBox.shrink().",
      "tokens": ["AppTypography.titleSm", "AppColors.textPrimary", "AppSpacing.screenHorizontal", "AppSpacing.md"],
      "reuses": "ArticleCard existente en lib/features/articles/presentation/widgets/article_card.dart"
    }
  ],

  "presentation_screen": {
    "file": "lib/features/articles/presentation/screens/article_detail_screen.dart",
    "class": "ArticleDetailScreen",
    "type": "StatelessWidget",
    "constructor": {
      "params": [
        { "name": "articleId", "type": "String", "required": true }
      ]
    },
    "bloc_provider": "BlocProvider(create: (_) => sl<ArticleDetailCubit>()..loadArticle(articleId, currentUserId))",
    "current_user_source": "context.read<AuthBloc>().state — obtener userId del AuthAuthenticated state",
    "app_bar": {
      "widget": "TortuAppBar.detail()",
      "actions": [
        {
          "icon": "Icons.share_outlined",
          "tooltip": "Compartir",
          "onPressed": "Share.share(article.title + '\\n' + AppRoutes.feedDetail(articleId))",
          "requires": "share_plus package",
          "only_visible_when": "state is ArticleDetailLoaded"
        }
      ]
    },
    "body_structure": {
      "layout": "CustomScrollView con Slivers",
      "slivers": [
        "SliverToBoxAdapter → ArticleCoverImage(imageUrl: article.coverHorizontalUrl)",
        "SliverPadding(screenHorizontal) → SliverList con:",
        "  - SizedBox(height: AppSpacing.xl)",
        "  - Text(article.title, style: AppTypography.titleLg)",
        "  - SizedBox(height: AppSpacing.lg)",
        "  - AuthorRow(author: author, readTimeMinutes: article.readTimeMinutes)",
        "  - Divider(color: AppColors.border)",
        "  - ArticleActionBar(isSaved: loaded.isSaved, onToggleSave: () => cubit.toggleSave(userId))",
        "  - Divider(color: AppColors.border)",
        "  - SizedBox(height: AppSpacing.xl)",
        "  - ArticleBodyRenderer(body: article.body)",
        "  - SizedBox(height: AppSpacing.huge)",
        "  - RelatedArticlesSection(articles: loaded.relatedArticles, onArticleTap: (id) => context.push(AppRoutes.feedDetail(id)))",
        "  - SizedBox(height: AppSpacing.huge)"
      ]
    },
    "states_handling": {
      "ArticleDetailLoading": "Center(child: CircularProgressIndicator(color: AppColors.primary))",
      "ArticleDetailLoaded": "CustomScrollView descrito arriba",
      "ArticleDetailError": "Center con Column: icono error, Text(message, AppTypography.body), TextButton('Reintentar', onPressed: () => cubit.loadArticle(articleId, userId))",
      "ArticleDetailInitial": "SizedBox.shrink()"
    },
    "save_error_handling": "BlocListener que reacciona cuando toggleSave falla → ScaffoldMessenger.of(context).showSnackBar(...)"
  },

