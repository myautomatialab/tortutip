  "domain_changes": {
    "new_use_cases": [
      {
        "file": "lib/features/articles/domain/use_cases/get_related_articles_use_case.dart",
        "class": "GetRelatedArticlesUseCase",
        "implements": "UseCase<DataState<List<ArticleEntity>>, GetRelatedArticlesParams>",
        "params_class": {
          "name": "GetRelatedArticlesParams",
          "fields": [
            { "name": "categoryId", "type": "String" },
            { "name": "excludeArticleId", "type": "String" }
          ]
        },
        "delegates_to": "ArticleRepository.getRelatedArticles(categoryId, excludeArticleId)"
      }
    ],
    "existing_use_cases_reused": [
      "GetArticleDetailUseCase",
      "SaveArticleUseCase",
      "UnsaveArticleUseCase",
      "GetSavedArticleIdsUseCase"
    ],
    "use_cases_NOT_to_create": [
      "LikeArticleUseCase — eliminado del scope"
    ],
    "repository_interface_additions": {
      "file": "lib/features/articles/domain/repository/article_repository.dart",
      "add_methods": [
        {
          "signature": "Future<DataState<List<ArticleEntity>>> getRelatedArticles(String categoryId, String excludeArticleId)",
          "note": "Devuelve hasta 5 artículos del mismo categoryId excluyendo el actual."
        }
      ],
      "do_NOT_add": [
        "likeArticle",
        "getLikedArticleIds"
      ]
    },
    "new_user_use_case": {
      "note": "GetUserByIdUseCase no existe aún. La sección autor carga el perfil del autor por su authorId.",
      "file": "lib/shared/user/domain/use_cases/get_user_by_id_use_case.dart",
      "class": "GetUserByIdUseCase",
      "implements": "UseCase<DataState<UserEntity>, String>",
      "delegates_to": "UserRepository.getUserById(userId)",
      "user_repository_addition": {
