{
  "plan_id": "article-detail-screen-v2",
  "feature": "ArticleDetailScreen",
  "scope_note": "Likes, comentarios y seguir-autor eliminados del scope. Solo bookmark, compartir y 'Más como esto'.",
  "created": "2026-05-31",

  "pubspec_changes": {
    "add_dependencies": [
