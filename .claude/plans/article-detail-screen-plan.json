      "tokens": ["AppTypography.body", "AppColors.textPrimary", "AppSpacing.screenHorizontal"]
    },
    {
      "file": "lib/features/articles/presentation/widgets/article_action_bar.dart",
      "class": "ArticleActionBar",
      "type": "StatelessWidget",
      "props": [
