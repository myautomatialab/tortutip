  "data_changes": {
    "article_repository_impl": {
      "file": "lib/features/articles/data/repository/article_repository_impl.dart",
      "add_method": {
        "name": "getRelatedArticles",
        "pattern": "try { final models = await _dataSource.getRelatedArticles(categoryId, excludeArticleId); return DataSuccess(models); } catch (e) { return DataFailed(e is Exception ? e : Exception(e.toString())); }"
      }
    },
    "article_remote_data_source": {
      "file": "lib/features/articles/data/data_sources/article_remote_data_source.dart",
      "add_to_abstract": "Future<List<ArticleModel>> getRelatedArticles(String categoryId, String excludeArticleId)",
      "impl_note": "Firestore: collection('articles').where('category_id', isEqualTo: categoryId).where('status', isEqualTo: 'published').limit(6) → filtra excludeArticleId en memoria → toma 5."
    },
    "mock_article_remote_data_source": {
      "file": "lib/features/articles/data/data_sources/mock_article_remote_data_source.dart",
      "add_method": "getRelatedArticles → devuelve los primeros 5 artículos mock del mismo categoryId excluyendo el actual."
    },
    "user_repository_impl": {
      "file": "lib/shared/user/data/repository/user_repository_impl.dart",
      "add_method": {
        "name": "getUserById",
        "pattern": "try { final model = await _dataSource.getUserById(userId); return DataSuccess(model); } catch (e) { return DataFailed(e is Exception ? e : Exception(e.toString())); }"
      }
    },
    "user_remote_data_source": {
      "file": "lib/shared/user/data/data_sources/user_remote_data_source.dart",
      "add_to_abstract": "Future<UserModel> getUserById(String userId)",
      "impl_note": "Firestore: collection('users').doc(userId).get()"
    },
    "mock_user_remote_data_source": {
      "file": "lib/shared/user/data/data_sources/mock_user_remote_data_source.dart",
      "add_method": "getUserById → devuelve un UserModel con datos mock basados en el userId."
    }
  },

  "presentation_bloc": {
    "state_file": "lib/features/articles/presentation/bloc/article_detail/article_detail_state.dart",
    "states": [
      {
        "class": "ArticleDetailInitial",
        "extends": "ArticleDetailState",
        "fields": [],
        "note": "Estado inicial del cubit."
      },
      {
        "class": "ArticleDetailLoading",
        "extends": "ArticleDetailState",
        "fields": [],
        "note": "Mientras carga el artículo principal."
      },
      {
        "class": "ArticleDetailLoaded",
        "extends": "ArticleDetailState",
        "fields": [
          { "name": "article", "type": "ArticleEntity", "nullable": false },
          { "name": "author", "type": "UserEntity", "nullable": false },
          { "name": "isSaved", "type": "bool", "nullable": false },
          { "name": "relatedArticles", "type": "List<ArticleEntity>", "nullable": false }
        ],
        "props": ["article", "author", "isSaved", "relatedArticles"],
        "fields_NOT_included": ["isLiked", "isFollowingAuthor", "likeCount"],
        "note": "Estado de éxito. isSaved es mutable por toggleSave."
      },
      {
        "class": "ArticleDetailError",
        "extends": "ArticleDetailState",
        "fields": [
          { "name": "message", "type": "String", "nullable": false }
        ],
        "props": ["message"],
        "note": "Error recuperable con mensaje legible para el usuario."
      },
      {
        "class": "ArticleDetailSaving",
        "extends": "ArticleDetailState",
        "fields": [
          { "name": "article", "type": "ArticleEntity", "nullable": false },
          { "name": "author", "type": "UserEntity", "nullable": false },
          { "name": "isSaved", "type": "bool", "nullable": false },
          { "name": "relatedArticles", "type": "List<ArticleEntity>", "nullable": false }
        ],
        "props": ["article", "author", "isSaved", "relatedArticles"],
        "note": "Opcional — se puede usar para mostrar spinner en el icono bookmark mientras se persiste."
      }
    ],

    "cubit_file": "lib/features/articles/presentation/bloc/article_detail/article_detail_cubit.dart",
    "cubit_class": "ArticleDetailCubit",
    "constructor_use_cases": [
      "GetArticleDetailUseCase",
      "GetRelatedArticlesUseCase",
      "SaveArticleUseCase",
      "UnsaveArticleUseCase",
      "GetUserByIdUseCase"
    ],
    "methods": [
      {
        "name": "loadArticle",
        "params": ["String articleId", "String currentUserId"],
        "steps": [
          "emit(ArticleDetailLoading())",
          "await _getArticleDetail(articleId) → DataState<ArticleEntity>",
          "Si falla → emit(ArticleDetailError(_mapErrorToMessage(error)))",
          "await _getUserById(article.authorId) → DataState<UserEntity>",
          "Si falla → emit(ArticleDetailError(...))",
          "await _getSavedArticleIds(currentUserId) → DataState<List<String>>",
          "isSaved = ids.contains(articleId)",
          "await _getRelatedArticles(GetRelatedArticlesParams(categoryId: article.categoryId, excludeArticleId: articleId))",
          "emit(ArticleDetailLoaded(article, author, isSaved, relatedArticles))"
        ],
        "note": "Todas las llamadas se hacen en paralelo con Future.wait donde no hay dependencia entre sí."
      },
      {
        "name": "toggleSave",
        "params": ["String userId"],
        "steps": [
          "Guard: si state no es ArticleDetailLoaded, return",
          "final loaded = state as ArticleDetailLoaded",
          "Optimistic update: emit(ArticleDetailLoaded(..., isSaved: !loaded.isSaved))",
          "Si isSaved era true → await _unsaveArticle(UnsaveArticleParams(...))",
          "Si isSaved era false → await _saveArticle(SaveArticleParams(...))",
          "Si falla → revertir emit con isSaved original + mostrar snackbar desde la Screen"
        ],
        "note": "Actualización optimista. El método no emite error directamente — retorna bool success para que la Screen decida."
      }
    ],
    "methods_NOT_to_add": [
      "toggleLike — eliminado del scope",
      "toggleFollowAuthor — eliminado del scope"
    ],
    "error_mapper": {
      "method": "_mapErrorToMessage",
      "cases": {
        "permission-denied": "No tienes permiso para ver este artículo",
        "not-found": "El artículo no existe",
        "unavailable": "Sin conexión. Inténtalo de nuevo",
        "_": "Algo salió mal. Inténtalo de nuevo"
      }
    }
  },

